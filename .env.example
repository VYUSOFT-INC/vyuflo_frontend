# Local development (Vite). Copy to `.env` and fill in values.
# Production / staging / etc. are injected by GitHub Actions into `.env.production` on the Droplet at deploy time.

# Backend API base (used by some features; axios mostly uses relative `/api/v1`)
VITE_API_BASE_URL=https://api.example.com/api/v1

# OAuth / SSO (public client IDs — still keep per-environment)
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=common
VITE_LINKEDIN_CLIENT_ID=

# Dev-server only: Vite proxy target for `/api` and `/static` (not used in Docker/production builds)
VITE_PROXY_TARGET=http://localhost:8001
